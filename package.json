{
  "name": "pi-auto-commit",
  "version": "0.1.0",
  "description": "Pi extension for agent-triggered, extension-owned git commit checkpoints.",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "files": [
    "README.md",
    "extensions"
  ],
  "scripts": {
    "validate": "npm run validate:load",
    "validate:load": "pi -e . --list-models >/dev/null 2>&1"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  }
}
